---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sectionApi, themeApi } from "../../lib/api";

export async function getStaticPaths() {
  const themes = await themeApi.getAll();

  return themes.map((theme) => ({
    params: { id: theme.id },
    props: { theme },
  }));
}

const { theme } = Astro.props;
const sections = await sectionApi.getByTheme(theme.id);
---

<BaseLayout title={`${theme.name} - Compass`}>
  <h1 class="text-slate-100 text-3xl text-center font-bold mb-6">
    {theme.name}
  </h1>
  <p class="text-slate-300 text-center mb-8">{theme.description}</p>

  <h2 class="text-slate-100 text-center text-xl font-semibold mb-4">
    Sections
  </h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {
      sections.map((section) => (
        <a
          href={`/sections/${section.id}`}
          class="bg-slate-800 hover:bg-slate-700 font-sans p-4 rounded-lg transition-colors"
        >
          <h3 class="text-slate-100 text-center font-sans font-semibold mb-2">
            {section.name}
          </h3>
          <p class="text-slate-400 font-sans text-sm">{section.description}</p>
        </a>
      ))
    }
  </div>
</BaseLayout>
