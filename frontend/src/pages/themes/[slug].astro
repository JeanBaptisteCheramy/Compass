---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const themes = await getCollection("themes");
  return themes.map((theme) => ({
    params: { slug: theme.slug },
    props: { theme },
  }));
}

const { theme } = Astro.props;

const allArticles = await getCollection("articles");
const articles = allArticles.filter((a) =>
  a.slug.startsWith(theme.slug + "/")
);

// Grouper les articles par section
const sections = articles.reduce(
  (acc, article) => {
    const section = article.data.section ?? "Non classé";
    if (!acc[section]) acc[section] = [];
    acc[section].push(article);
    return acc;
  },
  {} as Record<string, typeof articles>
);
---

<BaseLayout title={`${theme.data.title} - Compass`}>
  <Breadcrumb items={[{ name: "Accueil", url: "/" }, { name: theme.data.title }]} />

  <h1 class="text-slate-100 text-3xl text-center font-bold mb-6">
    {theme.data.title}
  </h1>
  {theme.data.description && (
    <p class="text-slate-300 text-center mb-8">{theme.data.description}</p>
  )}

  {Object.entries(sections).map(([sectionName, sectionArticles]) => (
    <div class="mb-8">
      <h2 class="text-slate-200 text-xl font-semibold mb-4">{sectionName}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {sectionArticles.map((article) => (
          <a
            href={`/articles/${article.slug}`}
            class="bg-slate-800 hover:bg-slate-700 font-sans p-4 rounded-lg transition-colors"
          >
            <h3 class="text-slate-100 font-sans font-semibold">
              {article.data.title}
            </h3>
          </a>
        ))}
      </div>
    </div>
  ))}
</BaseLayout>
