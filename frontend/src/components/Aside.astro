---
import Collapsible from "./Collapsible.astro";
import { getCollection } from "astro:content";

const themes = await getCollection("themes");
---

<aside
  class="bg-slate-950 p-3 flex flex-col gap-3 w-1/6 border-r border-r-indigo-950"
>
  {
    themes.map((theme) => (
      <Collapsible
        title={theme.data.title}
        style="primary"
        imageAlt={theme.data.title}
      >
      </Collapsible>
    ))
  }
</aside>
