---
import Collapsible from "./Collapsible.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("articles");
const themes = [...new Set(articles.map((a) => a.slug.split("/")[0]))].sort();

function makeTitle(str:string){
    return (str.charAt(0).toUpperCase() + str.slice(1)).replaceAll('-',' ')
}
---

<aside
  class="bg-slate-950 p-3 flex flex-col gap-3 w-1/6 border-r border-r-indigo-950"
>
  {
    themes.map((theme) => (
      <Collapsible title={makeTitle(theme)} style="primary">
        <div class="flex flex-col gap-1">
          {articles
            .filter((a) => a.slug.startsWith(theme + "/"))
            .map((article) => (
              <a
                href={`/articles/${article.slug}`}
                class="text-gray-50 text-sm hover:text-indigo-200 transition-all"
              >
                {article.data.title}
              </a>
            ))}
        </div>
      </Collapsible>
    ))
  }
</aside>
