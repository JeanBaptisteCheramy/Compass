---
export interface Props {
  title: string;
  style: string;
  defaultOpen?: boolean;
  imageUrl?: string;
  imageAlt?: string;
}

const {
  title,
  style = "primary",
  defaultOpen = false,
  imageUrl,
  imageAlt,
} = Astro.props;
const id = `collapsible-${Math.random().toString(36).substring(2, 9)}`;
let globalStyle = "";
switch (style) {
  case "secondary":
    globalStyle = "border-none bg-slate-500 hover:bg-indigo-900";
    break;
  default:
    globalStyle = "border-indigo-500 bg-slate-950 hover:bg-indigo-900";
}
---

<div
  class={`border ${globalStyle} rounded-xl transition-colors duration-200`}
  data-collapsible-container={id}
>
  <button
    type="button"
    class="flex font-sans w-full items-center justify-between p-2 text-left hover:bg-indigo-900 focus:outline-none transition-colors duration-200 rounded-xl"
    data-collapsible-trigger={id}
  >
    <div class="flex items-center gap-3">
      {
        imageUrl && (
          <div class="size-8 rounded-full overflow-hidden flex-shrink-0">
            <img
              src={imageUrl}
              alt={imageAlt || title}
              class="w-full h-full object-cover"
            />
          </div>
        )
      }
      <span class="font-medium font-sans text-gray-50">{title}</span>
    </div>

    <svg
      class="ml-3 h-5 w-5 text-gray-50 transition-transform duration-200"
      data-collapsible-icon={id}
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 9l-7 7-7-7"></path>
    </svg>
  </button>

  <div
    class="overflow-hidden transition-all duration-200"
    data-collapsible-content={id}
    style={defaultOpen ? "" : "max-height: 0;"}
  >
    <div class="p-4 pt-0 text-gray-50">
      <slot />
    </div>
  </div>
</div>

<script>
  // JavaScript pour l'interactivité
  document.addEventListener("DOMContentLoaded", function () {
    const triggers = document.querySelectorAll("[data-collapsible-trigger]");

    triggers.forEach((trigger) => {
      const id = trigger.getAttribute("data-collapsible-trigger");
      const content = document.querySelector(
        `[data-collapsible-content="${id}"]`
      ) as HTMLElement;
      const icon = document.querySelector(
        `[data-collapsible-icon="${id}"]`
      ) as HTMLElement;
      const container = document.querySelector(
        `[data-collapsible-container="${id}"]`
      ) as HTMLElement;

      if (content && icon && container) {
        trigger.addEventListener("click", () => {
          const isOpen =
            content.style.maxHeight && content.style.maxHeight !== "0px";

          if (isOpen) {
            // Fermer
            content.style.maxHeight = "0";
            icon.style.transform = "rotate(0deg)";
            container.style.backgroundColor = "";
            (trigger as HTMLElement).style.backgroundColor = "";
            (trigger as HTMLElement).classList.remove("rounded-t-xl");
            (trigger as HTMLElement).classList.add("rounded-xl");
          } else {
            // Ouvrir
            content.style.maxHeight = content.scrollHeight + "px";
            icon.style.transform = "rotate(180deg)";
            container.style.backgroundColor = "rgb(49 46 129)";
            (trigger as HTMLElement).style.backgroundColor = "rgb(49 46 129)";
            (trigger as HTMLElement).classList.remove("rounded-xl");
            (trigger as HTMLElement).classList.add("rounded-t-xl");
          }
        });
      }
    });
  });
</script>
